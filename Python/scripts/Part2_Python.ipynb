    "# Create and visualize the DAG\n",
    "nodes = ['Z3', 'Z1', 'Z2', 'X', 'Y']\n",
    "edges = [\n",
    "    ('X', 'Y'),      # Direct effect of X on Y\n",
    "    ('Z1', 'X'),     # Z1 affects X\n",
    "    ('Z1', 'Y'),     # Z1 affects Y\n",
    "    ('Z2', 'X'),     # Z2 affects X\n",
    "    ('Z2', 'Y'),     # Z2 affects Y\n",
    "    ('Z3', 'Z2'),    # Z3 affects Z2\n",
    "    ('Z3', 'Y')      # Z3 affects Y\n",
    "]\n",
    "\n",
    "create_dag_plot(nodes, edges, 'Part 2 DAG: Multiple Confounders Structure', 'part2_dag.png')"
